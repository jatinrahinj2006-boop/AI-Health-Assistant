# Vite bakes this value into the JS bundle at build time (npm run build).
# VITE_-prefixed vars are the only ones exposed to browser code.
# This points the static frontend at the Render FastAPI backend service.
# Override via Render dashboard > Environment > VITE_API_URL if backend URL changes.
VITE_API_URL=https://ai-health-assistant-km8x.onrender.com
