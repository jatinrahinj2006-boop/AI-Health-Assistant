# Application Environment (development or production)
ENV=development

# Server binding port
PORT=8000

# LLM provider config
LLM_PROVIDER=groq

# Groq API Configuration
GROQ_API_KEY="your_groq_api_key_here"

# Default Groq Models
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# CORS configuration
ALLOWED_ORIGINS=*
